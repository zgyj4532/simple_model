            "nlp_metric_scores"
          ],
          "imports": [
            "Validator",
            "Tokenizer"
          ],
          "optional": true
        },
        {
          "name": "VisionMetrics",
          "description": "用于计算视觉专用指标（mAP / IoU / FID / IS）",
          "exports": [
            "vision_metric_scores"
          ],
          "imports": [
            "Validator"
          ],
          "optional": true
        },
        {
          "name": "SpeechMetrics",
          "description": "用于计算语音专用指标（WER / CER）",
          "exports": [
            "speech_metric_scores"
          ],
          "imports": [
            "Validator"
          ],
          "optional": true
        },
        {
          "name": "RankingMetrics",
          "description": "用于计算检索/排序指标（NDCG / MRR / MAP）",
          "exports": [
            "ranking_scores"
          ],
          "imports": [
            "Validator"
          ],
          "optional": true
        },
        {
          "name": "GenerationMetrics",
