      "optional_args": ["--target-root", "--struct", "--budget", "--dry-run", "--apply", "--output-dir", "--json"],
      "output": "loop JSON or terminal report",
      "example": "simple_model_pi.sh --target-root /path/to/repo --struct /path/to/repo/struct.json optimize-loop --budget 3 --dry-run --json",
      "tests": ["tests/test_macro_optimizer.sh", "tests/test_plugin_package.sh"],
      "release_gate": true
    },
    {
      "name": "validate",
      "description": "Run simple_model validate, check-all, lint, and drift summaries.",
      "required_args": [],
      "optional_args": [],
      "output": "validation logs and JSON summaries",
      "example": "simple_model_pi.sh validate",
      "tests": ["tests/test_plugin_package.sh"],
      "release_gate": true
    },
    {
      "name": "full-check",
      "description": "Run the full simple_model validation and test suite.",
      "required_args": [],
      "optional_args": [],
      "output": "test logs",
      "example": "simple_model_pi.sh full-check",
      "tests": ["tests/test_plugin_package.sh"],
      "release_gate": false
    },
    {
      "name": "ingest",
      "description": "Draft a struct model from an existing repository.",
