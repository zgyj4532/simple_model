{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jsonsch/simple_model/chimeric.schema.json",
  "title": "Chimeric Bridge Declaration",
  "description": "用户声明文件 chimeric.json 的 schema。描述本项目与一个 peer（外部）项目之间的集成点：每个 integration_point 把 self 端的某个 export 对接到 peer 端 OpenAPI 中某个 operation，并附带 field_mapping / invariants / golden / round-trip 配置。所有算法验证都由 chimeric_verify.sh 跑，无需 AI 调用。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bridge",
    "self",
    "peer",
    "integration_points"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0",
      "description": "锁 1.0，向后不兼容则 bump"
    },
    "bridge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]{2,63}$",
          "description": "稳定 kebab id；用于 generated/.chimeric/<name>/ 子目录"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "self": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project",
        "components"
      ],
      "properties": {
        "project": {
          "type": "string",
          "description": "self 端标识——可写 'this'（指当前 struct.json）、'./struct.json'、或 'github_owner/repo@ref'"
        },
        "components": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "module",
              "component"
            ],
            "properties": {
              "module": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_]*$"
              },
              "component": {
                "type": "string",
                "pattern": "^[A-Z][A-Za-z0-9]*$"
              },
              "exports": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "列出的 export 名必须在 struct.json 中该 module/component 的 exports[] 中真实存在；verify 时校验"
              },
              "as": {
                "type": "string",
                "description": "可选：生成 adapter 类名覆盖默认推断"
              }
            }
          }
        }
      }
    },
    "peer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "spec"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "peer 项目的人类可读名（用于日志/可视化）"
        },
        "spec": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "source"
          ],
          "properties": {
            "kind": {
              "enum": [
                "openapi_3",
                "openapi_2"
              ],
              "description": "OpenAPI 版本号（暂不支持自动 OAS 2→3 转换；需要时让作者先用 npx swagger2openapi 转一遍）"
            },
            "source": {
              "oneOf": [
                {
                  "type": "string",
                  "description": "https:// URL / git locator 'owner/repo@ref:path' / 本地路径"
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "url",
                    "sha256"
                  ],
                  "properties": {
                    "url": {
                      "type": "string",
                      "format": "uri"
                    },
                    "sha256": {
                      "type": "string",
                      "pattern": "^[0-9a-f]{64}$",
                      "description": "下载后立即校验，不一致则视为 peer spec drift"
                    }
                  }
                }
              ]
            },
            "cache_path": {
              "type": "string",
              "default": "./generated/.chimeric/<bridge>/peer-spec.json",
              "description": "缓存到磁盘的位置（首次拉取后不重新下载除非 hash 变了）"
            }
          }
        }
      }
    },
    "integration_points": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/IntegrationPoint"
      }
    },
    "fixtures_dir": {
      "type": "string",
      "default": "./generated/.chimeric/<bridge>/fixtures",
      "description": "golden fixtures 与 round-trip 用例的根目录"
    }
  },
  "$defs": {
    "IntegrationPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "self_export",
        "peer_path",
        "peer_method"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]{2,63}$",
          "description": "短 id，用于文件名与日志"
        },
        "self_export": {
          "type": "string",
          "description": "self.components[].exports 中的一个名；adapter 暴露同名函数"
        },
        "peer_path": {
          "type": "string",
          "pattern": "^/",
          "description": "peer 端 OpenAPI 中真实存在的一个 path"
        },
        "peer_method": {
          "enum": [
            "GET",
            "POST",
            "PUT",
            "PATCH",
            "DELETE",
            "HEAD",
            "OPTIONS"
          ]
        },
        "status": {
          "enum": [
            "active",
            "deprecated",
            "experimental"
          ],
          "default": "active"
        },
        "optional": {
          "type": "boolean",
          "default": false
        },
        "comments": {
          "type": "string"
        },
        "field_mapping": {
          "type": "object",
          "description": "self_export 字段名 → peer 字段描述。值是字符串时表示直 rename；是对象时声明类型转换、必填、默认值、jq transform",
          "additionalProperties": {
            "oneOf": [
              {
                "type": "string",
                "description": "直接 rename：peer 端的字段名"
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "from",
                  "to"
                ],
                "properties": {
                  "from": {
                    "type": "string"
                  },
                  "to": {
                    "type": "string"
                  },
                  "type": {
                    "type": "string",
                    "description": "覆盖 OpenAPI 推断的类型；必须是 string/integer/number/boolean/array/object 之一"
                  },
                  "required": {
                    "type": "boolean",
                    "default": false
                  },
                  "default": {
                    "description": "peer 端缺该字段时填入的默认值（任意 JSON）"
                  },
                  "transform": {
                    "type": "string",
                    "description": "可选 jq 表达式，在 decode 时对 peer 字段值执行"
                  }
                }
              }
            ]
          }
        },
        "invariants": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "expression"
            ],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_]*$"
              },
              "expression": {
                "type": "string",
                "description": "jq 布尔表达式，作用于 decodes/raw 后的响应"
              },
              "severity": {
                "enum": [
                  "error",
                  "warning"
                ],
                "default": "error"
              },
              "applies_to": {
                "enum": [
                  "decoded",
                  "raw"
                ],
                "default": "decoded"
              }
            }
          }
        },
        "golden": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "response": {
              "type": "string",
              "description": "相对 fixtures_dir 的 golden 响应 fixture 路径"
            },
            "request": {
              "type": "string"
            }
          }
        },
        "round_trip": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "cases": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "fixture": {
                    "type": "string",
                    "description": "相对 fixtures_dir 的请求 fixture"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "examples": [
    {
      "schema_version": "1.0",
      "bridge": {
        "name": "auth-bridge",
        "description": "本项目 ↔ external-user-service 的登录接口桥接"
      },
      "self": {
        "project": "this",
        "components": [
          {
            "module": "auth",
            "component": "AuthAPI",
            "exports": [
              "login_token",
              "user_id",
              "expires_at"
            ]
          }
        ]
      },
      "peer": {
        "name": "external-user-service",
        "spec": {
          "kind": "openapi_3",
          "source": {
            "url": "https://raw.githubusercontent.com/example/external-user-service/v1.2.0/openapi.yaml",
            "sha256": "REPLACE_WITH_REAL_SHA256"
          }
        }
      },
      "integration_points": [
        {
          "id": "login",
          "self_export": "login_token",
          "peer_path": "/v1/users/login",
          "peer_method": "POST",
          "field_mapping": {
            "login_token": {
              "from": "token",
              "to": "login_token",
              "type": "string",
              "required": true
            },
            "user_id": {
              "from": "id",
              "to": "user_id",
              "type": "string",
              "required": true
            },
            "expires_at": {
              "from": "expires_at",
              "to": "expires_at",
              "type": "string"
            }
          },
          "invariants": [
            {
              "name": "token_nonempty",
              "expression": ".login_token | length > 20"
            },
            {
              "name": "expires_iso8601",
              "expression": ".expires_at | test(\"^[0-9]{4}-[0-9]{2}-[0-9]{2}T\")"
            }
          ],
          "golden": {
            "response": "login_response.json"
          },
          "round_trip": {
            "enabled": true,
            "cases": [
              { "name": "happy_path", "fixture": "login_request.json" }
            ]
          }
        }
      ]
    }
  ]
}
