            "LossFunction",
            "Optimizer",
            "LRScheduler",
            "Collator",
            "MixedPrecision",
            "GradientAccumulator",
            "GradientClipper",
            "EMA",
            "Callback",
            "SeedManager"
          ],
          "todos": [
            {
              "task": "实现 train loop：forward → loss → backward → step",
              "priority": "high",
              "id": "trainer_1",
              "status": "done",
              "blocks": [
                "trainer_2",
                "trainer_3"
              ]
            },
            {
              "task": "处理梯度累积（accumulation_steps）",
              "priority": "high",
              "id": "trainer_2",
              "status": "done",
              "blocks": [
                "trainer_3"
              ]
            },
            {
              "task": "处理 mixed precision（autocast + GradScaler）",
              "priority": "high",
              "id": "trainer_3",
              "status": "done"
            },
            {
              "task": "实现 eval loop 与 validation 调度",
              "priority": "medium",
              "id": "trainer_4",
              "status": "done"
            },
            {
              "task": "接入 DDP / FSDP 的 all-reduce 钩子",
              "priority": "medium",
              "id": "trainer_5",
              "status": "done"
            },
            {
              "task": "支持 resume from checkpoint",
              "priority": "medium",
              "id": "trainer_6",
              "status": "done"
            }
          ]
        },
        {
          "name": "Checkpoint",
          "description": "用于保存、加载与轮转模型检查点",
          "exports": [
            "checkpoint_artifact"
          ],
          "imports": [
            "Trainer"
          ]
        }
      ]
    },
    {
      "name": "hpo",
      "description": "超参数优化、神经架构搜索与早停策略",
      "components": [
        {
          "name": "SearchSpace",
          "description": "用于声明超参数搜索空间（连续/离散/条件）",
          "imports": [],
          "optional": true,
          "exports": [
            "search_space"
          ]
        },
        {
          "name": "SweepGenerator",
          "description": "用于生成网格搜索、随机搜索与贝叶斯搜索的配置矩阵",
          "exports": [
            "sweep_matrix"
          ],
          "imports": [
            "SearchSpace",
            "ConfigComposer"
          ],
          "optional": true
        },
        {
          "name": "TrialScheduler",
          "description": "用于调度并发 trial 并分配资源",
