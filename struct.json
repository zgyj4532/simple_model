            "predictions"
          ],
          "imports": [
            "Checkpoint",
            "DataSplitter",
            "AutoProcessor",
            "Collator"
          ],
          "todos": [
            {
              "task": "实现 model.eval() + no_grad 推理",
              "priority": "high",
              "id": "validator_1",
              "status": "done",
              "blocks": [
                "reporter_1"
              ]
            },
            {
              "task": "支持 TTA（test-time augmentation）",
              "priority": "medium",
              "id": "validator_2",
              "status": "done"
            },
            {
              "task": "汇总 predictions 与 labels 给后续 metrics",
              "priority": "high",
              "id": "validator_3",
              "status": "done"
            }
          ]
        },
        {
          "name": "MetricsCalculator",
          "description": "用于计算通用分类/回归指标（acc / F1 / MSE / AUC ...）",
