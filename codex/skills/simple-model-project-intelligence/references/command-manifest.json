    {
      "name": "facts",
      "description": "Emit normalized code facts for a target repository.",
      "required_args": [],
      "optional_args": ["repo", "--struct"],
      "output": "code facts JSON",
      "example": "simple_model_pi.sh --target-root /path/to/repo facts",
      "tests": ["tests/test_plugin_package.sh"],
      "release_gate": true
