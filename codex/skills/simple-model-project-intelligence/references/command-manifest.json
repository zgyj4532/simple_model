{
  "schema_version": "1.1",
  "commands": [
    {
      "name": "doctor",
      "description": "Diagnose plugin, toolchain, and target repository readiness.",
      "required_args": [],
      "optional_args": ["--target-root", "--struct", "--json"],
      "output": "human or JSON diagnostics",
      "example": "simple_model_pi.sh --target-root /path/to/repo doctor --json",
      "tests": ["tests/test_plugin_package.sh"],
      "release_gate": true
    },
    {
      "name": "commands",
      "description": "List available wrapper commands and their metadata.",
      "required_args": [],
      "optional_args": ["--json"],
      "output": "human list or command manifest JSON",
      "example": "simple_model_pi.sh commands --json",
      "tests": ["tests/test_plugin_package.sh"],
      "release_gate": true
    },
    {
      "name": "self-check",
      "description": "Run the plugin lifecycle gate and write self-audit JSON/Markdown reports.",
      "required_args": [],
      "optional_args": ["--json", "--output-dir"],
      "output": "human or JSON self-check report",
      "example": "simple_model_pi.sh self-check --json",
      "tests": ["tests/test_plugin_package.sh"],
      "release_gate": true
    },
    {
      "name": "self-audit",
      "description": "Generate or print the latest plugin self-audit report.",
      "required_args": [],
      "optional_args": ["--json", "--output-dir"],
      "output": "human summary or JSON self-audit report",
      "example": "simple_model_pi.sh self-audit --json",
      "tests": ["tests/test_plugin_package.sh"],
      "release_gate": true
    },
    {
      "name": "self-release",
      "description": "Validate and package a plugin release, with optional GitHub publish.",
      "required_args": ["--version"],
      "optional_args": ["--dry-run", "--publish", "--json"],
      "output": "release validation JSON",
      "example": "simple_model_pi.sh self-release --version 0.6.0 --dry-run --json",
      "tests": ["tests/test_plugin_package.sh"],
      "release_gate": true
    },
    {
      "name": "macros",
      "description": "List deterministic code and execution macros available to the optimizer.",
      "required_args": [],
      "optional_args": ["--json"],
      "output": "human summary or macro registry JSON",
      "example": "simple_model_pi.sh macros --json",
      "tests": ["tests/test_macro_optimizer.sh", "tests/test_plugin_package.sh"],
      "release_gate": true
    },
    {
      "name": "macro-suggest",
      "description": "Generate declarative macro specs from deterministic repo facts.",
      "required_args": [],
      "optional_args": ["--target-root", "--struct", "--output-dir", "--json"],
      "output": "macro suggestion JSON and per-spec files",
      "example": "simple_model_pi.sh --target-root /path/to/repo --struct /path/to/repo/struct.json macro-suggest --json",
      "tests": ["tests/test_macro_optimizer.sh", "tests/test_plugin_package.sh"],
      "release_gate": true
    },
    {
      "name": "macro-compile",
      "description": "Compile declarative macro specs into an executable optimization plan.",
      "required_args": [],
      "optional_args": ["--suggestions", "--output-dir", "--json"],
      "output": "compiled plan JSON",
      "example": "simple_model_pi.sh macro-compile --suggestions generated/optimization/macro-suggestions.json --json",
      "tests": ["tests/test_macro_optimizer.sh", "tests/test_plugin_package.sh"],
      "release_gate": true
    },
    {
      "name": "macro-run",
      "description": "Execute a generated optimization plan in dry-run or apply mode.",
      "required_args": ["--plan"],
      "optional_args": ["--dry-run", "--apply", "--macro", "--json"],
      "output": "human or JSON macro execution report",
      "example": "simple_model_pi.sh macro-run --plan generated/optimization/plan.json --dry-run --json",
      "tests": ["tests/test_macro_optimizer.sh", "tests/test_plugin_package.sh"],
      "release_gate": true
    },
    {
      "name": "score",
      "description": "Compute deterministic architecture health score from repo facts.",
      "required_args": [],
      "optional_args": ["--target-root", "--struct", "--output-dir", "--json"],
      "output": "score JSON or terminal summary",
      "example": "simple_model_pi.sh --target-root /path/to/repo --struct /path/to/repo/struct.json score --json",
      "tests": ["tests/test_macro_optimizer.sh", "tests/test_plugin_package.sh"],
      "release_gate": true
    },
    {
      "name": "optimize",
      "description": "Plan and execute deterministic macro optimization for a target repository.",
      "required_args": [],
      "optional_args": ["--target-root", "--struct", "--dry-run", "--apply", "--output-dir", "--json"],
      "output": "terminal report plus JSON/Markdown optimization artifacts",
      "example": "simple_model_pi.sh --target-root /path/to/repo --struct /path/to/repo/struct.json optimize --dry-run",
      "tests": ["tests/test_macro_optimizer.sh", "tests/test_plugin_package.sh"],
      "release_gate": true
    },
    {
      "name": "optimize-loop",
      "description": "Run score-driven macro suggestion, compilation, execution, validation, and rollback loop.",
