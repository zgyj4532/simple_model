      "example": "simple_model_pi.sh --target-root /path/to/repo pr-gate /path/to/repo src/api/server.ts",
      "tests": ["tests/test_plugin_package.sh"],
      "release_gate": true
    },
    {
      "name": "dashboard",
      "description": "Generate a static Project Intelligence dashboard.",
      "required_args": [],
      "optional_args": ["output"],
