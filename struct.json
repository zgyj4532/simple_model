          "exports": [
            "api_endpoint"
          ],
          "imports": [
            "ModelServer"
          ]
        },
        {
          "name": "CanaryDeployer",
          "description": "用于灰度发布、A/B 测试与版本回滚",
          "imports": [
            "ModelServer",
            "APIGateway"
          ],
          "optional": true,
          "exports": [
            "canary_deployer"
          ]
        },
        {
          "name": "DriftDetector",
          "description": "用于监控线上输入分布与输出置信度漂移",
          "exports": [
            "drift_alerts"
          ],
          "imports": [
            "ModelServer",
            "MetricRecorder"
          ],
          "optional": true
        }
      ]
    },
    {
      "name": "tracking",
      "description": "实验追踪、指标记录、产物管理与可视化",
      "components": [
        {
          "name": "SeedManager",
          "description": "用于设置并广播全局随机种子以保证可复现性",
          "imports": [],
          "exports": [
            "seed_manager"
          ]
        },
        {
          "name": "ExperimentTracker",
          "description": "用于对接 MLflow / Weights & Biases 等实验追踪平台",
          "exports": [
            "experiment_run"
          ],
          "imports": []
        },
        {
          "name": "MetricRecorder",
          "description": "用于记录标量、直方图、图像、文本等训练指标",
          "exports": [
            "metric_stream"
          ],
          "imports": [
            "ExperimentTracker"
          ]
        },
        {
          "name": "ArtifactStore",
          "description": "用于存储模型权重、配置文件与产物并打版本",
          "exports": [
            "artifact_uri"
          ],
          "imports": [
            "ExperimentTracker"
          ]
        },
        {
          "name": "Visualizer",
          "description": "用于 TensorBoard / WandB 风格的实时可视化",
          "imports": [
            "MetricRecorder"
          ],
          "exports": [
            "visualizer"
          ]
        }
      ]
    },
    {
      "name": "pipeline",
      "description": "训练流水线编排：任务依赖、调度、缓存与失败重试",
      "components": [
        {
          "name": "WorkflowScheduler",
          "description": "用于编排数据预处理、训练、评估、部署等多阶段任务",
          "imports": [
            "ConfigLoader"
          ],
          "exports": [
            "workflow_scheduler"
          ]
        },
        {
          "name": "TaskDAG",
          "description": "用于声明任务依赖图并自动解析执行顺序",
          "exports": [
            "execution_plan"
          ],
          "imports": [
            "WorkflowScheduler"
          ]
        },
        {
          "name": "PipelineCache",
          "description": "用于按内容哈希缓存中间产物以跳过未变更阶段",
          "exports": [
            "cache_hit_misses"
          ],
          "imports": [
            "TaskDAG"
          ],
          "optional": true
        },
        {
          "name": "RetryPolicy",
          "description": "用于任务失败重试、超时与告警",
          "imports": [
            "TaskDAG"
          ],
          "optional": true,
          "exports": [
            "retry_policy"
          ]
        }
      ]
    },
    {
      "name": "profile",
      "description": "性能与显存分析，定位训练/推理瓶颈",
      "components": [
        {
          "name": "Profiler",
          "description": "用于算子级耗时分析（PyTorch Profiler / Nsight）",
          "exports": [
            "profile_trace"
          ],
          "imports": [
            "Trainer",
            "InferenceEngine"
          ],
          "optional": true
        },
        {
          "name": "MemoryProfiler",
          "description": "用于显存峰值、碎片与生命周期分析",
          "exports": [
            "memory_trace"
          ],
          "imports": [
            "Trainer",
            "InferenceEngine"
          ],
          "optional": true
        },
        {
          "name": "BottleneckAnalyzer",
          "description": "用于识别数据 IO / 计算 / 通信瓶颈并给出建议",
          "exports": [
            "bottleneck_report"
          ],
          "imports": [
            "Profiler",
            "MemoryProfiler"
          ],
          "optional": true
        }
      ]
    },
    {
      "name": "test",
      "description": "测试体系：单元、集成、回归与质量门禁",
      "components": [
        {
          "name": "IntegrationTest",
          "description": "用于端到端跑通训练-评估-导出流程",
          "imports": [
            "WorkflowScheduler",
            "Reporter"
          ],
          "exports": [
            "integration_test"
          ]
        },
        {
          "name": "RegressionTest",
          "description": "用于在 CI 上对比新旧模型的指标回归",
          "imports": [
            "Reporter"
          ],
          "optional": true,
          "exports": [
            "regression_test"
          ]
        },
        {
          "name": "QualityGate",
          "description": "用于在合并前对模型设置最低指标门槛",
          "imports": [
            "Reporter"
          ],
          "optional": true,
          "exports": [
            "quality_gate"
          ]
        }
      ]
    },
    {
      "name": "repro",
      "description": "可复现性：环境快照、依赖锁定与产物审计",
      "components": [
        {
          "name": "EnvSnapshot",
          "description": "用于快照运行环境（OS / CUDA / 驱动 / 库版本）",
          "exports": [
            "env_manifest"
          ],
          "imports": []
        },
        {
          "name": "DependencyLocker",
          "description": "用于锁定 Python 与系统依赖以确保 bitwise 复现",
          "imports": [
            "EnvSnapshot"
          ],
          "optional": true,
          "exports": [
            "dependency_locker"
          ]
        },
        {
          "name": "AuditLogger",
          "description": "用于审计训练过程的关键事件以便回溯",
          "exports": [
            "audit_log"
          ],
          "imports": [
            "Trainer",
            "WorkflowScheduler"
          ]
        }
      ]
    }
  ],
  "phases": [
    {
      "phase": "configure",
      "order": 1,
      "mode": "sequential",
      "description": "加载并校验配置，按任务名拉取 AutoConfig",
      "core_components": [
        "ConfigLoader",
        "ConfigComposer",
        "ConfigValidator",
        "TaskRegistry",
        "AutoConfig"
      ]
    },
    {
      "phase": "prepare_data",
      "order": 2,
      "mode": "sequential",
      "description": "按任务拉取 Processor，加载、解析、切分、组装 batch",
      "core_components": [
        "AutoProcessor",
        "DataLoader",
        "DataParser",
        "DataSplitter",
        "Tokenizer",
        "ImageProcessor",
        "AudioFeatureExtractor",
        "Collator"
      ],
      "optional_components": [
        "DataCleaner",
        "VideoProcessor",
        "DataAugmenter",
        "DataCache",
        "DataVersion"
      ]
    },
    {
      "phase": "build_model",
      "order": 3,
      "mode": "sequential",
      "description": "按任务从 ModelRegistry 拉取 Backbone+Neck+Head，组装模型与优化器",
      "core_components": [
        "AutoModel",
        "ModelRegistry",
        "Backbone",
        "Neck",
        "Head",
        "ModelBuilder",
        "LossFunction",
        "Optimizer",
        "LRScheduler"
      ]
    },
    {
      "phase": "init_distributed",
      "order": 4,
      "mode": "select_one",
      "description": "按配置挑选一种分布式后端初始化进程组",
      "core_components": [
        "ClusterMonitor",
        "RankSync"
      ],
      "select_one_of": [
        "DDPLauncher",
        "FSDPManager",
        "DeepSpeedEngine",
        "TensorParallel"
      ]
    },
    {
      "phase": "train",
      "order": 5,
      "mode": "sequential",
      "description": "训练主循环，含混合精度、梯度管理、EMA、回调与检查点",
      "core_components": [
        "Trainer",
        "MixedPrecision",
        "Callback",
        "Checkpoint"
      ],
      "optional_components": [
        "GradientAccumulator",
        "GradientClipper",
        "EMA"
      ]
    },
    {
      "phase": "verify",
      "order": 6,
      "mode": "sequential",
      "description": "按任务路由到对应指标集并生成报告",
      "core_components": [
        "Validator",
        "TaskEvaluator",
        "MetricsCalculator",
        "Reporter"
      ],
      "optional_components": [
        "NLPMetrics",
        "VisionMetrics",
        "SpeechMetrics",
        "RankingMetrics",
        "GenerationMetrics",
        "Benchmark",
        "RobustnessProbe"
      ]
    },
    {
      "phase": "compress",
      "order": 7,
      "mode": "select_subset",
      "description": "按需执行量化、剪枝、蒸馏、图优化并导出跨平台格式",
      "core_components": [
        "Exporter"
      ],
      "select_subset_of": [
        "Quantizer",
        "Pruner",
        "Distiller",
        "GraphOptimizer"
      ]
    },
    {
      "phase": "deploy",
      "order": 8,
      "mode": "sequential",
      "description": "上线推理服务、暴露 API、灰度发布并接入漂移监控",
      "core_components": [
        "InferenceEngine",
        "ModelServer",
        "APIGateway"
      ],
      "optional_components": [
        "CanaryDeployer",
        "DriftDetector"
      ]
    }
  ],
  "cross_cutting": [
    {
      "name": "tracking",
      "description": "贯穿全程的实验追踪、产物记录与可视化",
      "injects_into": [
        "configure",
        "train",
        "verify",
        "compress",
        "deploy"
      ],
      "components": [
        "ExperimentTracker",
        "MetricRecorder",
        "ArtifactStore",
        "Visualizer"
      ]
    },
    {
      "name": "repro",
      "description": "贯穿全程的可复现性保障：种子、环境快照、依赖锁、审计",
      "injects_into": [
        "configure",
        "prepare_data",
        "train",
        "verify"
      ],
      "components": [
        "SeedManager",
        "EnvSnapshot",
        "AuditLogger"
      ]
    },
    {
      "name": "profile",
      "description": "在 train 与 deploy 阶段按需启用的性能与显存分析",
      "injects_into": [
        "train",
        "deploy"
      ],
      "default_enabled": false,
      "components": [
        "Profiler",
        "MemoryProfiler",
        "BottleneckAnalyzer"
      ]
    },
    {
      "name": "hpo",
      "description": "外层循环：包裹 configure→train→verify，按 trial 反复执行挑选最优超参",
      "injects_into": [
        "train",
        "verify"
      ],
      "default_enabled": false,
      "components": [
        "SearchSpace",
        "SweepGenerator",
        "TrialScheduler",
        "HPOTuner",
        "EarlyStopper",
        "NASEngine"
      ]
    },
    {
      "name": "pipeline",
      "description": "工作流编排：声明 DAG、缓存中间产物、按策略重试",
      "injects_into": [
        "configure",
        "prepare_data",
        "build_model",
        "train",
        "verify",
        "compress",
        "deploy"
      ],
      "components": [
        "WorkflowScheduler",
        "TaskDAG",
        "PipelineCache",
        "RetryPolicy"
      ]
    },
    {
      "name": "test",
      "description": "CI 与合并前门禁处运行的测试与质量门槛",
      "injects_into": [
        "verify"
      ],
      "components": [
        "UnitTest",
        "IntegrationTest",
        "RegressionTest",
        "QualityGate"
      ]
    }
  ]
}
