          ],
          "imports": [
            "Validator"
          ],
          "optional": true
        },
        {
          "name": "Reporter",
          "description": "用于生成指标矩阵、对比表与可视化报告",
          "exports": [
            "report"
          ],
          "imports": [
            "TaskEvaluator",
            "Benchmark",
            "RobustnessProbe"
          ],
          "todos": [
            {
              "task": "输出 JSON 指标摘要",
              "priority": "high",
              "id": "reporter_1",
              "status": "done",
              "blocks": [
                "reporter_2"
              ]
            },
            {
              "task": "生成 Markdown / HTML 对比报告",
              "priority": "medium",
              "id": "reporter_2",
              "status": "done"
            },
            {
              "task": "支持接入 MLflow / W&B 自动记录",
              "priority": "medium",
              "id": "reporter_3",
              "status": "done"
            }
          ]
        }
      ]
    },
    {
      "name": "compress",
      "description": "模型压缩：量化、剪枝、知识蒸馏与图优化",
      "components": [
        {
          "name": "Quantizer",
          "description": "用于训练后量化（PTQ）与量化感知训练（QAT），INT8/INT4/FP8",
          "exports": [
            "quantized_model"
          ],
          "imports": [
            "Checkpoint"
          ],
          "optional": true
        },
        {
          "name": "Pruner",
          "description": "用于结构化/非结构化剪枝以缩减参数量",
          "exports": [
            "pruned_model"
          ],
          "imports": [
            "Checkpoint",
            "ModelBuilder"
          ],
          "optional": true
        },
        {
          "name": "Distiller",
          "description": "用于知识蒸馏，将大模型能力迁移到小模型",
          "exports": [
            "student_model"
          ],
          "imports": [
            "Trainer",
            "Checkpoint"
          ],
          "optional": true
        },
        {
          "name": "Exporter",
          "description": "用于导出 ONNX / TensorRT / CoreML 等跨平台格式",
          "exports": [
            "exported_artifact"
          ],
          "imports": [
            "Checkpoint"
          ]
        },
        {
          "name": "GraphOptimizer",
          "description": "用于算子融合、内存规划与计算图优化（TVM / TorchInductor）",
          "exports": [
            "optimized_graph"
          ],
          "imports": [
            "Exporter"
          ],
          "optional": true
        }
      ]
    },
    {
      "name": "deploy",
      "description": "模型部署、服务化、推理优化与线上监控",
      "components": [
        {
          "name": "InferenceEngine",
          "description": "用于批处理、KV-cache、PagedAttention 等高性能推理",
          "exports": [
            "inference_runtime"
          ],
          "imports": [
            "Exporter"
          ]
        },
        {
          "name": "ModelServer",
          "description": "用于启动在线推理服务（TorchServe / Triton / vLLM）",
          "exports": [
            "running_service"
          ],
          "imports": [
            "InferenceEngine"
          ]
        },
        {
          "name": "APIGateway",
