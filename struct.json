            "SearchSpace"
          ],
          "optional": true,
          "exports": [
            "trial_scheduler"
          ]
        },
        {
          "name": "HPOTuner",
          "description": "用于驱动优化算法（贝叶斯/TPE/进化）寻找最优超参",
          "exports": [
            "best_hparams"
          ],
          "imports": [
            "TrialScheduler",
            "Trainer"
          ],
          "optional": true
        },
        {
          "name": "NASEngine",
