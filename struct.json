            "generation_scores"
          ],
          "imports": [
            "Validator"
          ],
          "optional": true
        },
        {
          "name": "TaskEvaluator",
          "description": "用于按任务名路由到对应指标集并汇总结果",
          "exports": [
            "task_metrics"
          ],
          "imports": [
            "TaskRegistry",
            "Validator",
            "MetricsCalculator"
          ]
        },
        {
          "name": "Benchmark",
          "description": "用于在标准基准上对比模型性能与吞吐",
          "exports": [
            "benchmark_report"
          ],
          "imports": [
            "TaskEvaluator"
          ],
          "optional": true
        },
        {
          "name": "RobustnessProbe",
          "description": "用于评估模型在对抗样本、噪声、分布漂移下的鲁棒性",
          "exports": [
