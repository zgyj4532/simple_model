      "example": "simple_model_pi.sh --target-root /path/to/repo --struct /path/to/struct.json audit",
      "tests": ["tests/test_plugin_package.sh"],
      "release_gate": true
    },
    {
      "name": "interfaces",
      "description": "Scan public interfaces and compare them with struct exports.",
