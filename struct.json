{
  "schema_version": "3.0",
  "description": "Simple Model — 多任务/多模态项目架构：模块定义、调用关系、数据流",
  "conventions": {
    "depends_on": "该服务直接调用的上游服务列表（仅记录直接调用，不展开传递依赖）",
    "produces": "该服务产出的核心 artifact / 数据，串联起来即完整数据流",
    "optional": "true 表示按需启用的扩展服务，false 或缺省为核心服务",
    "pipeline.stages": "按 order 升序执行的顺序阶段，构成完整训练-部署的 happy path",
    "pipeline.cross_cutting": "横切关注点：不参与主流程串行顺序，而是在多个阶段并行注入",
    "supported_tasks": "架构显式支持的任务清单，是 Auto* 派发的依据"
  },
  "modules": [
    {
      "name": "config",
      "description": "实验配置管理：层级配置、覆盖、校验",
      "components": [
        {
          "name": "ConfigLoader",
          "description": "用于从 YAML/JSON/TOML 加载配置并解析插值",
          "exports": [
            "config"
          ],
          "imports": []
        },
        {
          "name": "ConfigComposer",
          "description": "用于按层级合并、覆盖和继承多份配置",
          "exports": [
            "merged_config"
          ],
          "imports": [
            "ConfigLoader"
          ]
        },
        {
          "name": "ConfigValidator",
          "description": "用于在运行前校验配置合法性与字段约束",
          "exports": [
            "validation_report"
          ],
          "imports": [
            "ConfigComposer"
          ]
        }
      ]
    },
    {
      "name": "task",
      "description": "任务抽象与 Auto* 派发：多任务、多模态的自动装配",
      "components": [
        {
          "name": "TaskRegistry",
          "description": "用于按任务名注册与查找对应的数据、模型、指标、损失配置",
          "exports": [
            "task_descriptor"
          ],
          "imports": []
        },
        {
          "name": "TaskConfig",
          "description": "用于声明每种任务的输入/输出 schema、超参与评估约定",
          "exports": [
            "task_config"
          ],
          "imports": [
            "TaskRegistry"
          ]
        },
        {
          "name": "AutoConfig",
          "description": "用于按任务名自动加载对应的模型与训练配置",
          "exports": [
            "resolved_config"
          ],
          "imports": [
            "TaskRegistry",
            "ConfigLoader"
          ]
        },
        {
          "name": "AutoModel",
          "description": "用于按任务名自动装配 Backbone+Neck+Head（HuggingFace 风格）",
          "exports": [
            "model"
          ],
          "imports": [
            "TaskRegistry",
            "ModelRegistry",
            "ModelBuilder"
          ]
        },
        {
          "name": "AutoProcessor",
          "description": "用于按任务名自动选择并装配 Tokenizer/Image/Audio/Video Processor",
          "exports": [
            "processor_bundle"
          ],
          "imports": [
            "TaskRegistry",
            "Tokenizer",
            "ImageProcessor",
            "AudioFeatureExtractor",
            "VideoProcessor"
          ]
        },
        {
          "name": "MultiTaskWrapper",
          "description": "用于共享 Backbone 同时挂载多个任务 Head 的多任务学习",
          "exports": [
            "multi_task_model"
          ],
          "imports": [
            "Backbone",
            "Head",
            "LossFunction"
          ],
          "optional": true
        },
        {
          "name": "MultiModalFusion",
          "description": "用于跨模态特征融合（CLIP 风格图文对齐、视觉-语音等）",
          "exports": [
            "fused_embeddings"
          ],
          "imports": [
            "Backbone",
            "Neck"
          ],
          "optional": true
        }
      ]
    },
    {
      "name": "data",
      "description": "数据导入、预处理、增强、缓存与版本管理，含任务相关 Processor",
      "components": [
        {
          "name": "DataLoader",
          "description": "用于从各类数据源（文件/数据库/对象存储）导入数据",
          "exports": [
            "raw_samples"
          ],
          "imports": [],
          "todos": [
            {
              "task": "实现文件路径批量加载（CSV/JSONL/Parquet）",
              "priority": "high",
              "id": "data_loader_1",
              "status": "done",
              "blocks": [
                "data_parser_1"
              ]
            },
            {
              "task": "支持 S3 / OSS / GCS 对象存储后端",
              "priority": "medium",
              "id": "data_loader_2",
              "status": "done"
            },
            {
              "task": "实现流式迭代器，避免一次性载入全量数据",
              "priority": "high",
              "id": "data_loader_3",
              "status": "done"
            }
          ]
        },
        {
          "name": "DataParser",
          "description": "用于解析原始数据并转换为统一格式",
          "exports": [
            "parsed_dataset"
          ],
          "imports": [
            "DataLoader"
          ],
          "todos": [
            {
              "task": "定义统一的 schema（features / label / meta）",
              "priority": "high",
              "id": "data_parser_1",
              "status": "done",
              "blocks": [
                "data_splitter_1",
                "tokenizer_1"
              ]
            },
            {
              "task": "实现 schema 校验与缺失字段告警",
              "priority": "medium",
              "id": "data_parser_2",
              "status": "done"
            }
          ]
        },
        {
          "name": "DataCleaner",
          "description": "用于清洗数据中的噪声、缺失值和异常点",
          "exports": [
            "clean_dataset"
          ],
          "imports": [
            "DataParser"
          ],
          "optional": true
        },
        {
          "name": "DataSplitter",
          "description": "用于划分训练集、验证集和测试集",
          "exports": [
            "train_split",
            "val_split",
            "test_split"
          ],
          "imports": [
            "DataParser"
          ],
          "todos": [
            {
              "task": "支持随机切分与 stratified 切分",
              "priority": "high",
              "id": "data_splitter_1",
              "status": "done"
            },
            {
              "task": "支持按 group / 时间 / 客户等业务键切分",
              "priority": "medium",
              "id": "data_splitter_2",
              "status": "done"
            }
          ]
        },
        {
          "name": "Tokenizer",
          "description": "用于 NLP 文本的子词切分与 ID 映射（BPE / WordPiece / SentencePiece）",
          "exports": [
            "token_ids",
            "attention_mask"
          ],
          "imports": [],
          "todos": [
            {
              "task": "对接 HuggingFace tokenizers，支持 BPE/WordPiece/SP",
              "priority": "high",
              "id": "tokenizer_1",
              "status": "done"
            },
            {
              "task": "实现 batch 编码（truncation / padding / max_length）",
              "priority": "high",
              "id": "tokenizer_2",
              "status": "done"
            },
            {
              "task": "支持 special tokens 与 chat template",
              "priority": "medium",
              "id": "tokenizer_3",
              "status": "done"
            }
          ]
        },
        {
          "name": "ImageProcessor",
          "description": "用于图像的 resize / normalize / 色彩空间 / 几何变换",
          "exports": [
            "image_tensor"
          ],
          "imports": [],
          "todos": [
            {
              "task": "实现 torchvision / albumentations 两种后端",
              "priority": "high",
              "id": "image_processor_1",
              "status": "done"
            },
            {
              "task": "支持多尺度训练（multi-scale crop）",
              "priority": "medium",
              "id": "image_processor_2",
              "status": "done"
            }
          ]
        },
        {
          "name": "AudioFeatureExtractor",
          "description": "用于音频的 log-mel / 频谱 / fbank 特征提取",
          "exports": [
            "audio_features"
          ],
          "imports": [],
          "todos": [
            {
              "task": "实现 torchaudio / librosa 两套后端",
              "priority": "medium",
              "id": "audio_feature_extractor_1",
              "status": "done"
            },
            {
              "task": "支持 chunked 处理长音频",
              "priority": "medium",
              "id": "audio_feature_extractor_2",
              "status": "done"
            }
          ]
        },
        {
          "name": "VideoProcessor",
          "description": "用于视频的帧采样、解码与时空增强",
          "exports": [
            "video_tensor"
          ],
          "imports": [
            "ImageProcessor"
          ],
          "todos": [
            {
              "task": "实现 decord / PyAV 两种解码后端",
              "priority": "medium",
              "id": "video_processor_1",
              "status": "done"
            },
            {
              "task": "实现 uniform / random / keyframe 多种采样策略",
              "priority": "medium",
              "id": "video_processor_2",
              "status": "done"
            }
          ]
        },
        {
          "name": "Collator",
          "description": "用于把多条样本组装成 batch，处理 padding / attention mask / 序列对齐",
          "exports": [
            "batch"
          ],
          "imports": [
            "Tokenizer",
            "ImageProcessor",
            "AudioFeatureExtractor"
          ],
          "todos": [
            {
              "task": "实现多模态 batch 拼装（图+文+音对齐）",
              "priority": "high",
              "id": "collator_1",
              "status": "done"
            },
            {
              "task": "支持动态 padding 减少浪费",
              "priority": "medium",
              "id": "collator_2",
              "status": "done"
            }
          ]
        },
        {
          "name": "DataAugmenter",
          "description": "用于对训练数据进行增强（Mixup / CutMix / RandAug / TokenMask ...）",
          "exports": [
            "augmented_batch"
          ],
          "imports": [
            "DataSplitter",
            "ImageProcessor",
            "Tokenizer"
          ],
          "optional": true
        },
        {
          "name": "DataCache",
          "description": "用于将预处理结果缓存到本地或分布式存储以加速迭代",
          "exports": [
            "cached_dataset"
          ],
          "imports": [
            "DataParser",
            "DataCleaner"
          ],
          "optional": true
        },
        {
          "name": "DataVersion",
          "description": "用于数据集的版本管理与血缘追踪（DVC / LakeFS）",
          "exports": [
            "dataset_version_pointer"
          ],
          "imports": [
            "DataCache"
          ],
          "optional": true
        }
      ]
    },
    {
      "name": "model",
      "description": "模型组件库：Backbone + Neck + Head 可组合架构，模型注册中心",
      "components": [
        {
          "name": "Backbone",
          "description": "用于特征提取的主干网络（ResNet / ViT / BERT / Wav2Vec2 / GCN ...）",
          "exports": [
            "feature_maps"
          ],
          "imports": [],
          "todos": [
            {
              "task": "接入 timm / torchvision 的视觉 Backbone",
              "priority": "high",
              "id": "backbone_1",
              "status": "done",
              "blocks": [
                "model_builder_1"
              ]
            },
            {
              "task": "接入 transformers 的 NLP Backbone",
              "priority": "high",
              "id": "backbone_2",
              "status": "done"
            },
            {
              "task": "支持冻结/解冻特定 stage 的参数",
              "priority": "medium",
              "id": "backbone_3",
              "status": "done"
            }
          ]
        },
        {
          "name": "Neck",
          "description": "用于连接 Backbone 与 Head 的中间模块（FPN / ASPP / Adapter / Q-Former ...）",
          "exports": [
            "neck_features"
          ],
          "imports": [],
          "todos": [
            {
              "task": "实现 FPN / ASPP 等视觉 Neck",
              "priority": "medium",
              "id": "neck_1",
              "status": "done"
            },
            {
              "task": "实现 LoRA / Adapter 等参数高效迁移模块",
              "priority": "medium",
              "id": "neck_2",
              "status": "done"
            }
          ]
        },
        {
          "name": "Head",
          "description": "用于任务特定的输出层（分类 / 检测 / 分割 / 生成 / 检索 ...）",
          "exports": [
            "task_output"
          ],
          "imports": [],
          "todos": [
            {
              "task": "实现分类 / 检测 / 分割三类基础 Head",
              "priority": "high",
              "id": "head_1",
              "status": "done",
              "blocks": [
                "model_builder_1"
              ]
            },
            {
              "task": "实现 LM Head（含 tied weights）",
              "priority": "medium",
              "id": "head_2",
              "status": "done"
            }
          ]
        },
        {
          "name": "Initializer",
          "description": "用于参数初始化策略（Xavier / Kaiming / DeepSpeed-init）",
          "imports": [],
          "exports": [
            "initializer"
          ]
        },
        {
          "name": "ModelRegistry",
          "description": "用于按名称注册与查找模型架构（timm / transformers 风格）",
          "imports": [],
          "todos": [
            {
              "task": "实现 @register 装饰器注册模型",
              "priority": "high",
              "id": "model_registry_1",
              "status": "done",
              "blocks": [
                "model_builder_1"
              ]
            },
            {
              "task": "支持按字符串名动态构建模型",
              "priority": "high",
              "id": "model_registry_2",
              "status": "done"
            }
          ],
          "exports": [
            "model_registry"
          ]
        },
        {
          "name": "ModelBuilder",
          "description": "用于按配置组装 Backbone + Neck + Head，构造完整模型",
          "exports": [
            "model"
          ],
          "imports": [
            "ModelRegistry",
            "Backbone",
            "Neck",
            "Head",
            "Initializer"
          ],
          "todos": [
            {
              "task": "按 config 拼装 Backbone→Neck→Head 并返回完整模型",
              "priority": "high",
              "id": "model_builder_1",
              "status": "done",
              "blocks": [
                "trainer_1"
              ]
            },
            {
              "task": "支持从 yaml/json 配置直接构造",
              "priority": "medium",
              "id": "model_builder_2",
              "status": "done"
            }
          ]
        },
        {
          "name": "LossFunction",
          "description": "用于任务特定的损失函数（CE / Focal / Dice / CTC / Contrastive ...）",
          "exports": [
            "loss_value"
          ],
          "imports": [
            "TaskRegistry"
          ],
          "todos": [
            {
              "task": "按 task 名路由到对应 loss",
              "priority": "high",
              "id": "loss_function_1",
              "status": "done",
              "blocks": [
                "trainer_1"
              ]
            },
            {
              "task": "支持 label smoothing / class weighting",
              "priority": "medium",
              "id": "loss_function_2",
              "status": "done"
            }
          ]
        },
        {
          "name": "Optimizer",
          "description": "用于定义模型训练所用的优化器及其参数",
          "imports": [],
          "todos": [
            {
              "task": "实现 AdamW / SGD / Lion 等基础优化器",
              "priority": "high",
              "id": "optimizer_1",
              "status": "done"
            },
            {
              "task": "支持 per-layer lr / weight decay 分组",
              "priority": "medium",
              "id": "optimizer_2",
              "status": "done"
            }
          ],
          "exports": [
            "optimizer"
          ]
        },
        {
          "name": "LRScheduler",
          "description": "用于定义学习率调度策略（warmup / cosine / plateau）",
          "imports": [
            "Optimizer"
          ],
          "exports": [
            "lr_scheduler"
          ]
        },
        {
          "name": "ModelHub",
          "description": "用于下载、上传和分享预训练模型权重",
          "exports": [
            "pretrained_weights"
          ],
          "imports": [
            "ModelRegistry"
          ],
          "optional": true
        }
      ]
    },
    {
      "name": "distributed",
      "description": "分布式训练基础设施：DDP / FSDP / DeepSpeed / 多机多卡",
      "components": [
        {
          "name": "ClusterMonitor",
          "description": "用于监控集群节点、GPU 利用率与网络状态",
          "exports": [
            "cluster_state"
          ],
          "imports": []
        },
        {
          "name": "RankSync",
          "description": "用于跨进程同步、广播与 barrier",
          "imports": [
            "ClusterMonitor"
          ],
          "exports": [
            "rank_sync"
          ]
        },
        {
          "name": "DDPLauncher",
          "description": "用于启动分布式数据并行（DDP）训练",
          "exports": [
            "ddp_process_group"
          ],
          "imports": [
            "ClusterMonitor",
            "RankSync"
          ]
        },
        {
          "name": "FSDPManager",
          "description": "用于全分片数据并行（FSDP）的参数、梯度、优化器状态分片",
          "exports": [
            "fsdp_wrappers"
          ],
          "imports": [
            "ClusterMonitor",
            "RankSync"
          ]
        },
        {
          "name": "DeepSpeedEngine",
          "description": "用于封装 DeepSpeed 配置（ZeRO / Offload / Pipeline Parallel）",
          "exports": [
            "deepspeed_engine"
          ],
          "imports": [
            "ClusterMonitor",
            "RankSync"
          ]
        },
        {
          "name": "TensorParallel",
          "description": "用于张量并行切分（Megatron 风格）",
          "exports": [
            "tp_sharded_model"
          ],
          "imports": [
            "ClusterMonitor",
            "RankSync"
          ]
        }
      ]
    },
    {
      "name": "train",
      "description": "训练引擎：训练循环、混合精度、回调系统、梯度管理",
      "components": [
        {
          "name": "MixedPrecision",
          "description": "用于 fp16 / bf16 / fp8 混合精度训练以加速并节省显存",
          "exports": [
            "scaled_loss"
          ],
          "imports": []
        },
        {
          "name": "GradientAccumulator",
          "description": "用于累积多步梯度以模拟大 batch 训练",
          "exports": [
            "accumulated_grad"
          ],
          "imports": [],
          "optional": true
        },
        {
          "name": "GradientClipper",
          "description": "用于梯度裁剪以避免训练发散",
          "imports": [],
          "optional": true,
          "exports": [
            "gradient_clipper"
          ]
        },
